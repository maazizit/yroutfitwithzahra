# Copie ce fichier en `.env` puis remplis les valeurs.
# ⚠️ Le fichier .env est ignoré par git : il ne sera JAMAIS poussé sur GitHub.
#
# Variables à recréer dans GitHub → Settings → Secrets and variables → Actions :
#   EXPO_PUBLIC_SUPABASE_URL
#   EXPO_PUBLIC_SUPABASE_KEY
#   SUPABASE_DB_PASSWORD
#   SUPABASE_ACCESS_TOKEN
#   GEMINI_API_KEY
#   AWIN_FEED_URL

# App mobile (publiques par design)
EXPO_PUBLIC_SUPABASE_URL=https://cuwtknywzfyvhuuvvrpd.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your_publishable_key

# Admin Supabase (scripts uniquement)
SUPABASE_DB_PASSWORD=your_postgres_password
# Optionnel — token CLI (format sbp_...) depuis supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token
SUPABASE_PROJECT_REF=cuwtknywzfyvhuuvvrpd

# IA Gemini (gratuit : https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Awin (https://ui.awin.com → Outils → Create-a-Feed → CSV → URL)
AWIN_PUBLISHER_ID=2982087
AWIN_FEED_URL=https://productdata.awin.com/datafeed/download/...
